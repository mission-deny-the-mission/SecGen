<?xml version="1.0"?>

<scenario xmlns="http://www.github/cliffe/SecGen/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.github/cliffe/SecGen/scenario">

  <name>LLM Narrative Demo: Healthcare Data Breach Investigation</name>
  <author>SecGen AI Integration</author>
  <description>A demonstration scenario where students investigate a healthcare
  data breach. Uses LLM-generated evidence documents including email chains,
  chat logs, system logs, and database records to create an immersive
  forensic investigation experience.</description>

  <type>ctf</type>
  <type>forensics-ctf</type>
  <difficulty>hard</difficulty>

  <CyBOK KA="SOIM" topic="Security Operations and Incident Management">
    <keyword>INCIDENT RESPONSE</keyword>
    <keyword>DIGITAL FORENSICS</keyword>
  </CyBOK>

  <!-- LLM-generated narrative for the investigation -->
  <narrative theme="investigation" cybok_ka="SOIM">
    <introduction>
      <generator type="llm_ctf_narrative">
        <input into="theme">
          <value>investigation</value>
        </input>
        <input into="cybok_ka">
          <value>SOIM</value>
        </input>
      </generator>
    </introduction>
    <documents>
      <document type="email_chain" name="breach_communications">
        <generator type="llm_email_chain">
          <input into="theme">
            <value>data_breach</value>
          </input>
          <input into="num_emails">
            <value>7</value>
          </input>
        </generator>
      </document>
      <document type="chat_log" name="incident_channel">
        <generator type="llm_chat_log">
          <input into="theme">
            <value>data_breach</value>
          </input>
          <input into="chat_type">
            <value>incident_channel</value>
          </input>
        </generator>
      </document>
      <document type="log_entry" name="auth_logs">
        <generator type="llm_log_entry">
          <input into="theme">
            <value>data_breach</value>
          </input>
          <input into="log_type">
            <value>authentication</value>
          </input>
        </generator>
      </document>
    </documents>
  </narrative>

  <system>
    <system_name>analyst_vm</system_name>
    <base distro="Kali" name="MSF"/>

    <input into_datastore="IP_addresses">
      <value>172.16.0.2</value>
      <value>172.16.0.3</value>
    </input>

    <utility module_path=".*/parameterised_accounts">
      <input into="accounts">
        <value>{"username":"analyst","password":"analyst","super_user":"true","strings_to_leak":[],"leaked_filenames":[]}</value>
      </input>
    </utility>

    <network type="private_network">
      <input into="IP_address">
        <datastore access="0">IP_addresses</datastore>
      </input>
    </network>
    <input into_datastore="spoiler_admin_pass">
      <generator type="strong_password_generator"/>
    </input>
    <build type="cleanup">
      <input into="root_password">
        <datastore>spoiler_admin_pass</datastore>
      </input>
    </build>
  </system>

  <system>
    <system_name>healthcare_server</system_name>
    <base distro="Debian 12" type="desktop" name="KDE"/>

    <!-- LLM-generated healthcare organisation -->
    <input into_datastore="organisation">
      <generator type="llm_organisation">
        <input into="industry">
          <value>Healthcare</value>
        </input>
        <input into="theme">
          <value>data_breach</value>
        </input>
      </generator>
    </input>

    <input into_datastore="password">
      <generator type="random_sanitised_word">
        <input into="wordlist">
          <value>wordlist</value>
        </input>
        <input into="min_length">
          <value>6</value>
        </input>
      </generator>
    </input>

    <utility module_path=".*/parameterised_accounts">
      <input into="accounts">
        <generator type="account">
          <input into="password">
            <datastore>password</datastore>
          </input>
          <input into="super_user">
            <value>false</value>
          </input>
          <input into="leaked_filenames">
            <value>patient_records</value>
          </input>
          <input into="strings_to_leak">
            <generator type="flag_generator" module_path=".*/flag_words"/>
          </input>
        </generator>
      </input>
    </utility>

    <vulnerability module_path=".*(nostromo_code_exec)" privilege="user_rwx" access="remote" read_fact="strings_to_leak">
      <input into="strings_to_leak">
        <generator type="flag_generator" module_path=".*/flag_words"/>
      </input>
      <input into="organisation">
        <datastore>organisation</datastore>
      </input>
    </vulnerability>

    <network type="private_network">
      <input into="IP_address">
        <datastore access="1">IP_addresses</datastore>
      </input>
    </network>
    <build type="cleanup">
      <input into="root_password">
        <datastore>spoiler_admin_pass</datastore>
      </input>
    </build>
  </system>

</scenario>
