<html>
<head>
	<title><%= @title %></title>
</head>
<body>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
	body {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
		color: #24292e;
		background: #fff;
		margin: 0;
		padding: 0;
		line-height: 1.6;
	}
	.toc {
		float: left;
		font-size: smaller;
		color: #1a1d22;
		width: 280px;
		position: fixed;
		height: calc(100% - 40px);
		overflow-y: auto;
		padding: 20px;
		border-right: 1px solid #eaecef;
		background: #fafbfc;
		font-family: sans-serif;
	}
	.toc h3 {
		margin-top: 0;
		font-size: 1em;
		color: #555;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.toc ul {
		list-style-type: none;
		padding: 0;
		margin-left: 1em;
	}
	.toc li {
		margin: 0.5em 0;
	}
	.toc a {
		color: #0366d6;
		text-decoration: none;
	}
	.toc a:hover {
		text-decoration: underline;
	}
	article {
		float: right;
		width: calc(100% - 340px);
		padding: 30px 40px;
		box-sizing: border-box;
	}
	.markdown-body h1 { border-bottom: 1px solid #eaecef; padding-bottom: 0.3em; }
	.markdown-body h2 { border-bottom: 1px solid #eaecef; padding-bottom: 0.3em; margin-top: 1.5em; }
	.markdown-body h3 { margin-top: 1.2em; }
	.markdown-body pre {
		background-color: #f6f8fa;
		border-radius: 3px;
		padding: 16px;
		overflow: auto;
		font-size: 85%;
	}
	.markdown-body code {
		background-color: rgba(27,31,35,0.05);
		border-radius: 3px;
		padding: 0.2em 0.4em;
		font-size: 85%;
	}
	.markdown-body blockquote {
		border-left: 4px solid #dfe2e5;
		padding: 0 1em;
		color: #6a737d;
	}
	.hint-box {
		background: #fff8e1;
		border-left: 4px solid #ffc107;
		padding: 10px 16px;
		margin: 1em 0;
		border-radius: 3px;
	}
	.hint-box summary {
		cursor: pointer;
		font-weight: bold;
		color: #795548;
	}
	.hint-box.hint-big {
		background: #fce4ec;
		border-left-color: #e91e63;
	}
	.hint-box.hint-big summary {
		color: #c2185b;
	}
	.flag-submission {
		background: #e8f5e9;
		border: 1px solid #c8e6c9;
		border-radius: 4px;
		padding: 16px;
		margin: 1.5em 0;
	}
	.flag-submission code {
		background: #fff;
		border: 1px solid #a5d6a7;
		padding: 2px 6px;
		border-radius: 3px;
		font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
	}
	.system-info {
		background: #e3f2fd;
		border: 1px solid #bbdefb;
		border-radius: 4px;
		padding: 12px 16px;
		margin: 1em 0;
	}
	.system-info table {
		margin: 0;
	}
	.system-info td {
		padding: 2px 12px 2px 0;
	}
	.system-info td:first-child {
		font-weight: bold;
		color: #555;
	}
	.cybok-tag {
		display: inline-block;
		background: #e8eaf6;
		color: #283593;
		border-radius: 3px;
		padding: 2px 8px;
		margin: 2px;
		font-size: 0.85em;
	}
	@media (max-width: 767px) {
		.toc {
			float: none;
			width: 100%;
			position: relative;
			overflow: auto;
			height: auto;
			border-right: none;
			border-bottom: 1px solid #eaecef;
		}
		article {
			float: none;
			width: 100%;
			padding: 20px;
		}
	}
</style>

<div class="toc">
	<h3>Contents</h3>
	<%= @toc_html %>
</div>

<article class="markdown-body">
	<%= @body_html %>
</article>

</body>
</html>