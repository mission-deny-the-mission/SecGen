<?xml version="1.0"?>

<generator xmlns="http://www.github/cliffe/SecGen/generator"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://www.github/cliffe/SecGen/generator">
  <name>LLM Log Entry Generator</name>
  <author>SecGen AI Integration</author>
  <module_license>MIT</module_license>
  <description>Generates realistic system log entries using LLM for cybersecurity training. Supports authentication, system events, web access, firewall, and application logs.</description>

  <type>llm_log_entry</type>
  <type>llm_narrative</type>
  <type>llm_evidence</type>

  <platform>linux</platform>
  <platform>unix</platform>

  <read_fact>organisation</read_fact>
  <read_fact>theme</read_fact>
  <read_fact>log_type</read_fact>
  <read_fact>system_name</read_fact>
  <read_fact>time_range</read_fact>
  <read_fact>seed</read_fact>
  <read_fact>llm_model</read_fact>

  <default_input into="theme">
    <value>insider_threat</value>
  </default_input>
  <default_input into="log_type">
    <value>authentication</value>
  </default_input>

  <output_type>narrative_content</output_type>
</generator>
