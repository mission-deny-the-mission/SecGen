<% require 'json'
	 require 'securerandom'
	 require 'fileutils'
	 require 'erb'

	 if self.accounts.empty?
		 abort('Sorry, you need to provide an account')
	 end

	 $first_account = JSON.parse(self.accounts.first)

	 $main_user = $first_account['username'].to_s

	 $root_password = self.root_password
	 $flags = self.flags

	 REQUIRED_FLAGS = 4
	 while $flags.length < REQUIRED_FLAGS
		 $flags << "flag{#{SecureRandom.hex}}"
		 Print.err "Warning: Not enough flags provided to hackerbot_config generator, some flags won't be tracked/marked!"
	 end

	 # IP addresses - must match scenario.xml datastore
	 $gateway_lan_ip    = '10.0.1.1'
	 $desktop_ip        = '10.0.1.10'
	 $gateway_dmz_ip    = '10.0.2.1'
	 $webserver_ip      = '10.0.2.10'
	 $gateway_server_ip = '10.0.3.1'
	 $server_ip         = '10.0.3.10'

	 # Randomised values for challenges
	 $new_desktop_ip = "10.0.1.#{rand(50..99)}"

	 # regenerate bytes that include "D" because they render as smiley faces :D-|<
	 def printable_byte
		 loop do
			 b = rand(256)
			 return b unless ("%02X" % b).include?("D")
		 end
	 end

	 $new_mac = "00:AB:CD:%02X:%02X:%02X" % [printable_byte, printable_byte, printable_byte]

	 def get_binding
		 binding
	 end %>

<?xml version="1.0"?>

<hackerbot
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.github/cliffe/SecGen/hackerbot">

	<name>Hackerbot</name>

	<AIML_chatbot_rules>config/AIML</AIML_chatbot_rules>

	<get_shell>sshpass -p <%= $root_password %> ssh -oStrictHostKeyChecking=no root@<%= $desktop_ip %> /bin/bash</get_shell>

	<messages>
		<show_attack_numbers />

		<greeting>Welcome to the Network Security Fundamentals lab. I'll be setting you challenges to test your networking and security skills. Complete them and I'll give you flags. Let's get started!</greeting>

		<say_ready>Let me know when you are 'ready', if you want to move on to another challenge, say 'next', or 'previous' and I'll move things along.</say_ready>
		<say_ready>When you are ready, simply say 'ready'.</say_ready>
		<say_ready>'Ready'?</say_ready>
		<say_ready>Better hurry... Let me know when you're 'ready'.</say_ready>
		<next>Ok, moving to the next challenge...</next>
		<next>Next challenge...</next>
		<next>Ok, onwards...</next>
		<previous>Ok, going back...</previous>
		<previous>Ok, previous challenge...</previous>
		<previous>Ok, backing up.</previous>
		<goto>Ok, skipping ahead.</goto>
		<goto>Let me see what I can do to goto that challenge.</goto>
		<last_attack>That was the last challenge for now. Well done! (End.)</last_attack>
		<last_attack>That was the last challenge. Great work!</last_attack>
		<first_attack>You are back to the beginning!</first_attack>
		<first_attack>This is where it all began.</first_attack>
		<getting_shell>Ok. Checking your configuration...</getting_shell>
		<getting_shell>Verifying...</getting_shell>
		<getting_shell>Let me check that...</getting_shell>
		<getting_shell>Here we go...</getting_shell>
		<got_shell>Connected to your system.</got_shell>
		<got_shell>Access confirmed.</got_shell>
		<got_shell>We have shell.</got_shell>
		<repeat>Let me know when you are 'ready', if you want to move on, say 'next', or 'previous'.</repeat>
		<repeat>Say 'ready', 'next', or 'previous'.</repeat>

		<help>I am waiting for you to say 'ready', 'next', 'previous', 'list', 'goto *X*', or 'answer *X*'</help>
		<say_answer>Say "The answer is X".</say_answer>
		<no_quiz>There is no question to answer</no_quiz>
		<correct_answer>Correct</correct_answer>
		<incorrect_answer>Incorrect</incorrect_answer>
		<invalid>That's not possible.</invalid>
		<non_answer>Wouldn't you like to know.</non_answer>

		<shell_fail_message>Oh no. Failed to connect... Check your network configuration.</shell_fail_message>
	</messages>

	<tutorial_info>
		<title>Network Security Fundamentals: Network Design, Segmentation, NAT and DMZ</title>
		<tutorial><%= ERB.new(File.read self.templates_path + 'intro.md.erb').result(self.get_binding) %></tutorial>
		<footer>
<%= ERB.new(File.read self.templates_path + 'resources.md.erb').result(self.get_binding) %>
<%= ERB.new(File.read self.templates_path + 'license.md.erb').result(self.get_binding) %>
Randomised instance generated by [SecGen](http://github.com/cliffe/SecGen) (<%= Time.new.to_s %>)
		</footer>

		<provide_tutorial>true</provide_tutorial>

	</tutorial_info>


	<!-- =================================================================
	     SECTION 1: Network Reconnaissance &amp; Routing
	     Theory: network design, routing, IP forwarding, SSH hopping
	     Challenge: Connect the network
	     ================================================================= -->

	<attack>
		<prompt>All four VMs are on separate segments but have no default routes configured, and the gateway is not forwarding traffic. You will need to: (1) enable IP forwarding on the gateway, (2) set a default gateway on the desktop pointing at 10.0.1.1, (3) set a default gateway on the web_server pointing at 10.0.2.1, and (4) set a default gateway on the server pointing at 10.0.3.1. Use SSH to hop between systems as needed. You may find some flags along the way. Say 'ready' when the network is fully connected.</prompt>
		<post_command>ping -c 1 -W 3 <%= $webserver_ip %> > /dev/null 2>/dev/null; status1=$?; ping -c 1 -W 3 <%= $server_ip %> > /dev/null 2>/dev/null; status2=$?; echo NETCHECK-$status1$status2-</post_command>
		<suppress_command_output_feedback />
		<condition>
			<output_matches>NETCHECK-00-</output_matches>
			<message>:) The network is fully connected! <%= $flags.pop %></message>
			<trigger_next_attack>true</trigger_next_attack>
		</condition>
		<condition>
			<output_matches>NETCHECK-0[1-9]-</output_matches>
			<message>:( Your desktop can reach the webserver but not the server. Check the default route on the server (should point to <%= $gateway_server_ip %>).</message>
		</condition>
		<condition>
			<output_matches>NETCHECK-[1-9]0-</output_matches>
			<message>:( Your desktop can reach the server but not the webserver. Check the default route on the webserver (should point to <%= $gateway_dmz_ip %>).</message>
		</condition>
		<else_condition>
			<message>:( The desktop cannot reach either VM. Make sure you have: (1) enabled IP forwarding on the gateway, (2) set default routes on all VMs pointing at the gateway's IP on their local segment.</message>
		</else_condition>
		<tutorial>
<%= ERB.new(File.read self.templates_path + 'network_design.md.erb').result(self.get_binding) %>

---

<%= ERB.new(File.read self.templates_path + 'reconnaissance_routing.md.erb').result(self.get_binding) %>
		</tutorial>
	</attack>


	<!-- =================================================================
	     SECTION 2: IP and MAC Address Fundamentals
	     Theory: IP addresses, MAC addresses, spoofing implications
	     Challenges: Change IP, change MAC
	     ================================================================= -->

	<attack>
		<get_shell>sshpass -p <%= $root_password %> ssh -oStrictHostKeyChecking=no root@<%= $new_desktop_ip %> /bin/bash</get_shell>
		<prompt>Change your desktop's IP address to <%= $new_desktop_ip %> by editing /etc/network/interfaces and restarting networking. Make sure you keep connectivity to the gateway. Say 'ready' when done.</prompt>
		<post_command>ip addr show ens19 | grep <%= $new_desktop_ip %> > /dev/null; status1=$?; ping -c 1 -W 3 <%= $gateway_lan_ip %> > /dev/null 2>/dev/null; status2=$?; echo IPCHECK-$status1$status2-</post_command>
		<suppress_command_output_feedback />
		<condition>
			<output_matches>IPCHECK-00-</output_matches>
			<message>:) Your desktop is responding at <%= $new_desktop_ip %> and can reach the gateway. <%= $flags.pop %> Note: your desktop's IP has changed. Use <%= $new_desktop_ip %> for the rest of the lab.</message>
			<trigger_next_attack>true</trigger_next_attack>
		</condition>
		<condition>
			<output_matches>IPCHECK-0[1-9]-</output_matches>
			<message>:( Your desktop has the new IP but cannot reach the gateway. Check the gateway line in /etc/network/interfaces.</message>
		</condition>
		<condition>
			<output_matches>IPCHECK-[1-9]0-</output_matches>
			<message>:( The IP address does not appear to be set correctly. Edit /etc/network/interfaces and set the address to <%= $new_desktop_ip %>/24.</message>
		</condition>
		<else_condition>
			<message>:( Could not verify your desktop at <%= $new_desktop_ip %> or it cannot reach the gateway. Edit /etc/network/interfaces to set the new address and run: sudo service networking restart</message>
		</else_condition>
		<tutorial><%= ERB.new(File.read self.templates_path + 'ip_fundamentals.md.erb').result(self.get_binding) %></tutorial>
	</attack>

	<attack>
		<get_shell>sshpass -p <%= $root_password %> ssh -oStrictHostKeyChecking=no root@<%= $new_desktop_ip %> /bin/bash</get_shell>
		<prompt>Change your desktop's MAC address to <%= $new_mac %>. Make sure you maintain connectivity. Say 'ready' when done.</prompt>
		<post_command>ip link show ens19 | grep -i "<%= $new_mac.downcase %>" > /dev/null; status1=$?; ping -c 1 -W 3 <%= $gateway_lan_ip %> > /dev/null 2>/dev/null; status2=$?; echo MACCHECK-$status1$status2-</post_command>
		<suppress_command_output_feedback />
		<condition>
			<output_matches>MACCHECK-00-</output_matches>
			<message>:) MAC address changed successfully and connectivity maintained. <%= $flags.pop %></message>
			<trigger_next_attack>true</trigger_next_attack>
		</condition>
		<condition>
			<output_matches>MACCHECK-0[1-9]-</output_matches>
			<message>:( MAC address is correct but you have lost connectivity to the gateway. Check your network configuration.</message>
		</condition>
		<condition>
			<output_matches>MACCHECK-[1-9]0-</output_matches>
			<message>:( MAC address has not been changed. Expected <%= $new_mac %> on ens19. Check with: ip link show ens19</message>
		</condition>
		<else_condition>
			<message>:( Could not verify the MAC address change or connectivity. Expected <%= $new_mac %> on ens19.</message>
		</else_condition>
		<tutorial><%= ERB.new(File.read self.templates_path + 'mac_fundamentals.md.erb').result(self.get_binding) %></tutorial>
	</attack>


	<!-- =================================================================
	     SECTION 3: Firewall Rules &amp; Segmentation
	     Theory: firewall concepts, iptables practical, NAT
	     Challenge: Verify firewall segmentation is correct
	     ================================================================= -->

	<attack>
		<pre_shell>dt_to_ws=$(sshpass -p <%= $root_password %> ssh -oStrictHostKeyChecking=no <%= $main_user %>@<%= $new_desktop_ip %> 'ping -c 1 -W 3 <%= $webserver_ip %> > /dev/null 2>/dev/null; echo $?'); dt_to_srv=$(sshpass -p <%= $root_password %> ssh -oStrictHostKeyChecking=no <%= $main_user %>@<%= $new_desktop_ip %> 'ping -c 1 -W 3 <%= $server_ip %> > /dev/null 2>/dev/null; echo $?'); ws_to_srv=$(sshpass -p <%= $root_password %> ssh -oStrictHostKeyChecking=no <%= $main_user %>@<%= $webserver_ip %> 'ping -c 1 -W 3 <%= $server_ip %> > /dev/null 2>/dev/null; echo $?'); echo FWTEST-$dt_to_ws-$dt_to_srv-$ws_to_srv-</pre_shell>
		<get_shell>false</get_shell>
		<suppress_command_output_feedback />
		<prompt>Configure iptables on the gateway to enforce network segmentation: the desktop should be able to reach both the webserver and server, but the webserver must NOT be able to reach the server. Follow the instructions in the labsheet to set up the rules, then say 'ready' when done.</prompt>
		<condition>
			<output_matches>FWTEST-0-0-1-</output_matches>
			<message>:) Your firewall rules are correct! The desktop can reach both zones and the DMZ is properly isolated. <%= $flags.pop %></message>
			<trigger_next_attack>true</trigger_next_attack>
		</condition>
		<condition>
			<output_matches>FWTEST-0-0-0-</output_matches>
			<message>:( The webserver can still reach the server. Make sure there is no rule allowing DMZ to server zone traffic, and that the FORWARD policy is DROP.</message>
		</condition>
		<condition>
			<output_matches>FWTEST-[1-9]-[1-9]-</output_matches>
			<message>:( The desktop cannot reach either zone. Make sure you have FORWARD rules allowing 10.0.1.0/24 to 10.0.2.0/24 and 10.0.3.0/24, and an ESTABLISHED,RELATED rule for return traffic.</message>
		</condition>
		<condition>
			<output_matches>FWTEST-0-[1-9]-</output_matches>
			<message>:( The desktop can reach the webserver but not the server. Add a FORWARD rule allowing 10.0.1.0/24 to 10.0.3.0/24.</message>
		</condition>
		<condition>
			<output_matches>FWTEST-[1-9]-0-</output_matches>
			<message>:( The desktop can reach the server but not the webserver. Add a FORWARD rule allowing 10.0.1.0/24 to 10.0.2.0/24.</message>
		</condition>
		<else_condition>
			<message>:( Something went wrong with the check. Make sure all VMs are reachable and IP forwarding is enabled on the gateway.</message>
		</else_condition>
		<tutorial>
<%= ERB.new(File.read self.templates_path + 'firewall_concepts.md.erb').result(self.get_binding) %>

---

<%= ERB.new(File.read self.templates_path + 'iptables_practical.md.erb').result(self.get_binding) %>

---

<%= ERB.new(File.read self.templates_path + 'nat.md.erb').result(self.get_binding) %>

---

<%= ERB.new(File.read self.templates_path + 'dmz_concepts.md.erb').result(self.get_binding) %>

