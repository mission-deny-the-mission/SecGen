<%#
  ZeroClaw TOML Configuration Template for SecGen
  This template generates ZeroClaw-compatible TOML configs from SecGen datastore values
  
  Available variables:
  - $first_account, $second_account: Account hashes from datastore
  - $main_user, $main_password: Primary student credentials
  - $root_password: Root password for VMs
  - $flags: Array of flag values
  - $irc_server_ip, $irc_port: IRC server connection details
  - $scenario_id: Scenario identifier
%>
# ZeroClaw Hackerbot Configuration
# Generated by SecGen for scenario: <%= $scenario_id || 'hackerbot_training' %>
# Generated: <%= Time.now.iso8601 %>
# 
# This configuration is auto-generated from SecGen datastore values.
# Do not edit manually - changes will be overwritten on VM regeneration.

# ─────────────────────────────────────────────────────────────────────────────
# Core Configuration
# ─────────────────────────────────────────────────────────────────────────────

[hackerbot]
scenario_id = "<%= $scenario_id || 'hackerbot_training' %>"
irc_server = "<%= $irc_server_ip || 'localhost' %>"
irc_port = <%= $irc_port || 6668 %>
default_personality = "red_team"

# SecGen integration settings
[secgen]
enabled = true
datastore_path = "/var/lib/secgen/datastore.json"
main_username = "<%= $main_user || 'student' %>"
main_password = "<%= $main_password || 'password' %>"
root_password = "<%= $root_password || 'rootpass' %>"

# ─────────────────────────────────────────────────────────────────────────────
# Flag Configuration
# Flags are stored encrypted and validated via secgen_flag_validator tool
# ─────────────────────────────────────────────────────────────────────────────

<% ($flags || []).each_with_index do |flag, index| %>
[[flags]]
id = "flag_<%= index + 1 %>"
value = "<%= flag %>"
description = "Flag <%= index + 1 %> for <%= $scenario_id || 'hackerbot_training' %>"
points = 100
<% end %>

# ─────────────────────────────────────────────────────────────────────────────
# Training Scenarios
# Each scenario includes prompt, flag requirement, and validation
# ─────────────────────────────────────────────────────────────────────────────

[[scenarios]]
index = 0
title = "Initial Reconnaissance"
prompt = "Begin by gathering information about the target system at <%= $desktop_ip || '172.16.0.2' %>. What services are running? What ports are open? Use nmap to scan the target and identify potential entry points."
flag_id = "flag_1"
hint = "Try using nmap with the -sS flag for a stealthy SYN scan..."
difficulty = "easy"

[[scenarios]]
index = 1
title = "Service Enumeration"
prompt = "Now that you've identified open ports, enumerate the services running on the target. What versions are they running? Are there any known vulnerabilities?"
flag_id = "flag_2"
hint = "Use nmap with -sV to detect service versions..."
difficulty = "easy"

[[scenarios]]
index = 2
title = "Initial Access"
prompt = "Gain initial access to the system using the credentials you've discovered or vulnerabilities you've identified."
flag_id = "flag_3"
hint = "Check for weak credentials or misconfigured services..."
difficulty = "medium"

[[scenarios]]
index = 3
title = "User Flag Capture"
prompt = "Once you have user-level access, locate and capture the user flag."
flag_id = "flag_4"
hint = "Flags are often stored in the user's home directory..."
difficulty = "medium"

[[scenarios]]
index = 4
title = "Privilege Escalation"
prompt = "Escalate your privileges from user to root. Look for misconfigurations, SUID binaries, or kernel vulnerabilities."
flag_id = "flag_5"
hint = "Check for SUID binaries with find / -perm -4000..."
difficulty = "hard"

[[scenarios]]
index = 5
title = "Root Flag Capture"
prompt = "With root access, locate and capture the root flag."
flag_id = "flag_6"
hint = "The root flag is typically in /root/..."
difficulty = "medium"

[[scenarios]]
index = 6
title = "Lateral Movement"
prompt = "Move laterally to the backup server at <%= $backup_server_ip || '172.16.0.3' %>. Use the credentials you've discovered to access the second system."
flag_id = "flag_7"
hint = "Try using SSH with the credentials you found..."
difficulty = "hard"

[[scenarios]]
index = 7
title = "Data Exfiltration Simulation"
prompt = "Simulate data exfiltration by locating sensitive files and documenting what an attacker could steal."
flag_id = "flag_8"
hint = "Look in /home/*/personal_secrets/ and /home/*/trade_secrets/..."
difficulty = "medium"

[[scenarios]]
index = 8
title = "Persistence Mechanism"
prompt = "Identify how an attacker could maintain persistent access to the system."
flag_id = "flag_9"
hint = "Check cron jobs, SSH keys, and startup scripts..."
difficulty = "hard"

[[scenarios]]
index = 9
title = "Covering Tracks"
prompt = "Document how an attacker would cover their tracks after compromising the system."
flag_id = "flag_10"
hint = "Check log files in /var/log/..."
difficulty = "medium"

# ─────────────────────────────────────────────────────────────────────────────
# Personality Configuration
# Four personalities available: red_team, blue_team, researcher, instructor
# ─────────────────────────────────────────────────────────────────────────────

[agents.red_team]
provider = "ollama"
model = "gemma3:1b"
system_prompt = """
You are an offensive security expert helping students learn penetration testing.
Focus on attack techniques, exploitation methods, and real-world adversary tactics.
Always emphasize ethical and legal considerations.
Reference MITRE ATT&CK techniques when relevant.
"""
agentic = true
allowed_tools = ["shell", "scenario_manager", "secgen_datastore_query", "secgen_flag_validator"]
max_iterations = 10
temperature = 0.7

[agents.blue_team]
provider = "ollama"
model = "gemma3:1b"
system_prompt = """
You are a defensive security expert helping students learn threat detection and response.
Focus on identifying attacks, implementing controls, and incident response.
Reference MITRE ATT&CK mitigations and detection opportunities.
"""
agentic = true
allowed_tools = ["shell", "scenario_manager", "secgen_datastore_query", "secgen_flag_validator"]
max_iterations = 10
temperature = 0.7

[agents.researcher]
provider = "ollama"
model = "gemma3:1b"
system_prompt = """
You are a security researcher helping students understand vulnerability analysis and threat intelligence.
Focus on technical depth, research methodology, and evidence-based analysis.
Cite sources and reference real-world incidents when relevant.
"""
agentic = true
allowed_tools = ["shell", "scenario_manager", "secgen_datastore_query", "web_search"]
max_iterations = 10
temperature = 0.8

[agents.instructor]
provider = "ollama"
model = "gemma3:1b"
system_prompt = """
You are a cybersecurity instructor helping students learn and prepare for certifications.
Focus on clear explanations, learning objectives, and exam-relevant content.
Use analogies and structured explanations to make concepts accessible.
"""
agentic = true
allowed_tools = ["scenario_manager", "secgen_datastore_query", "schedule"]
max_iterations = 10
temperature = 0.6

# ─────────────────────────────────────────────────────────────────────────────
# Security Policy
# Configured for educational use with appropriate safeguards
# ─────────────────────────────────────────────────────────────────────────────

[security]
workspace_dir = "/opt/zeroclaw/workspace"
shell_allowlist = ["nmap", "tcpdump", "iptables", "ssh", "sshpass", "netcat", "curl", "wget", "ping", "dig", "nslookup", "whois", "traceroute", "mtr", "arp", "ip", "ifconfig", "route", "ss", "lsof", "strace", "find", "grep", "cat", "less", "head", "tail", "wc", "sort", "uniq", "awk", "sed", "cut", "tr", "base64", "openssl", "gpg"]
shell_denylist = ["rm -rf /", "mkfs", "dd if=/dev/zero", ":(){:|:&};:", "chmod -R 777 /", "chown -R"]
require_approval_for = ["network_scan_external", "firewall_change", "credential_access", "privilege_escalation"]
rate_limit_actions_per_hour = 100

[autonomy]
level = "supervised"

# ─────────────────────────────────────────────────────────────────────────────
# Memory and RAG Configuration
# ─────────────────────────────────────────────────────────────────────────────

[memory]
backend = "sqlite"
db_path = "/opt/zeroclaw/memory.db"

[memory.rag]
enabled = true
collection_name = "cybersecurity_<%= $scenario_id || 'training' %>"
max_results = 5
similarity_threshold = 0.3

# ─────────────────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────────────────

[observability]
backend = "log"
log_path = "/var/log/zeroclaw/hackerbot.log"
log_level = "info"
