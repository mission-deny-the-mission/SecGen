# ZeroClaw Hackerbot overlay configuration
# Generated by Puppet for SecGen integration.

irc_server = "<%= @irc_server_ip %>"
irc_port = <%= @irc_port %>
irc_nickname = "Hackerbot"
irc_channel = "#hackerbot"
allowed_users = ["*"]
secgen_datastore_path = "<%= @secgen_datastore_path %>"
ollama_host = "<%= @ollama_host %>"
ollama_port = <%= @ollama_port %>
model = "<%= @ollama_model %>"

[security]
level = "standard"
