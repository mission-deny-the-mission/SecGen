# ZeroClaw Main Configuration
# Generated by Puppet for SecGen integration
# 
# This configuration file is managed by Puppet and should not be edited manually.
# Bot-specific configurations are loaded from /opt/zeroclaw/hackerbot/bot_*.toml

# Core Configuration
default_provider = "ollama"
default_model = "<%= @ollama_model %>"
default_temperature = 0.7

[agent]
max_tool_iterations = 15
max_history_messages = 100
parallel_tools = true

# Ollama Configuration
[ollama]
host = "<%= @ollama_host %>"
port = <%= @ollama_port %>

# SecGen Integration
[secgen]
enabled = true
datastore_path = "/var/lib/secgen/datastore.json"

# Memory Configuration
[memory]
backend = "sqlite"
db_path = "/var/lib/zeroclaw/memory.db"

[memory.rag]
enabled = true
collection_name = "secgen_hackerbot"
max_results = 5
similarity_threshold = 0.3

# Security Configuration
[security]
workspace_dir = "/opt/zeroclaw/workspace"
shell_allowlist = ["nmap", "tcpdump", "iptables", "ssh", "sshpass", "netcat", "curl", "wget", "ping", "dig", "nslookup", "whois", "traceroute", "mtr", "arp", "ip", "ifconfig", "route", "ss", "lsof", "strace", "find", "grep", "cat", "less", "head", "tail", "wc", "sort", "uniq", "awk", "sed", "cut", "tr", "base64", "openssl", "gpg"]

[autonomy]
level = "supervised"

# Observability
[observability]
backend = "log"
log_path = "/var/log/zeroclaw/zeroclaw.log"
log_level = "info"

# Load bot-specific configurations
# These are generated by SecGen and deployed by Puppet
<% @hackerbot_configs.each_with_index do |config, index| %>
include "<%= "/opt/zeroclaw/hackerbot/bot_#{index}.toml" %>"
<% end %>
