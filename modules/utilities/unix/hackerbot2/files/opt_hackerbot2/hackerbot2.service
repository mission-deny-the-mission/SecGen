[Unit]
Description=Hackerbot2 IRC attack chatbot (SecGen project)
After=network.target

[Service]
ExecStart=/bin/bash -c "/usr/bin/ruby /opt/hackerbot2/hackerbot.rb"
ExecReload=/bin/kill -HUP $MAINPID
KillMode=process
WorkingDirectory=/opt/hackerbot2
Restart=always
Environment="SHELL=/bin/bash"
Environment="HOME=/root"

[Install]
WantedBy=multi-user.target